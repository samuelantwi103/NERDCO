# Incident Service — Environment Variables
# Copy this file to .env and fill in real values before starting the service

# Neon PostgreSQL connection string for incident_db
DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/incident_db?sslmode=require

# Service port
PORT=3002

# RS256 public key (same key pair as auth-service — auth-service holds the private key)
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n<base64>\n-----END PUBLIC KEY-----"

# CloudAMQP RabbitMQ URL
RABBITMQ_URL=amqps://<user>:<password>@<host>.cloudamqp.com/<vhost>

# URL of the tracking service (for vehicle status updates during dispatch)
TRACKING_SERVICE_URL=http://localhost:3003

# URL of the auth service (for hospital capacity queries)
AUTH_SERVICE_URL=http://localhost:3001

# Shared secret for service-to-service calls (must match auth-service SERVICE_INTERNAL_SECRET)
SERVICE_INTERNAL_SECRET=
