# Tracking Service — Environment Variables
# Copy this file to .env and fill in real values before starting the service

# Neon PostgreSQL connection string for tracking_db
DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/tracking_db?sslmode=require

# Service port
PORT=3003

# RS256 public key (same key pair as auth-service)
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n<base64>\n-----END PUBLIC KEY-----"

# CloudAMQP RabbitMQ URL
RABBITMQ_URL=amqps://<user>:<password>@<host>.cloudamqp.com/<vhost>
