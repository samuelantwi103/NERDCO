{
  "name": "auth-service",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && node -e \"require('fs').cpSync('src/docs', 'dist/docs', { recursive: true, force: true })\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@nerdco/domain-types": "workspace:*",
    "bcryptjs":    "^2.4.3",
    "cors":        "^2.8.5",
    "dotenv":      "^16.4.5",
    "express":     "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "amqplib":     "^0.10.4",
    "pg":          "^8.12.0",
    "uuid":        "^10.0.0",
    "swagger-ui-express": "^5.0.1",
    "js-yaml":     "^4.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
