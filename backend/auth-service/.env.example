# Auth Service — Environment Variables
# Copy this file to .env and fill in real values before starting the service

# Neon PostgreSQL connection string for auth_db
DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/auth_db?sslmode=require

# Service port
PORT=3001

# RS256 key pair — generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Paste the PEM content with literal \n instead of real newlines
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n<base64>\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n<base64>\n-----END PUBLIC KEY-----"

# Shared secret for internal service-to-service calls (GET /auth/verify)
# Leave blank in local dev to skip the check. Set in production.
SERVICE_INTERNAL_SECRET=

# Brevo (https://brevo.com) — free tier: 300 emails/day, no domain required
# Used for password reset emails. Leave blank to disable email sending (local dev).
BREVO_API_KEY=
EMAIL_FROM=noreply@nerdco.gov.gh
EMAIL_FROM_NAME=NERDCO Emergency Platform

# Frontend URL — used to build password reset links in emails
FRONTEND_URL=http://localhost:3000
